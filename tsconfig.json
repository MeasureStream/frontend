{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler", // <-- CAMBIA DA "Node" A "bundler"
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "noEmit": true,
    "types": [
      "react",
      "react-dom"
    ] // <-- AGGIUNGI QUESTA RIGA
  },
  "include": [
    "src"
  ]
}
